# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ──────────────────────────────────────────────────
# URL is the same as the existing project
SUPABASE_URL=https://ovmlohgptdiryvlwztxz.supabase.co
# Service role key (from Supabase → Project Settings → API → service_role)
# Used by the agents server. NEVER expose this in the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Slack ─────────────────────────────────────────────────────
# From api.slack.com → Your App → OAuth & Permissions → Bot Token
SLACK_BOT_TOKEN=xoxb-...
# From api.slack.com → Your App → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=...
# Slash command and interactive components request URL:
#   https://YOUR_RAILWAY_URL/slack/events

# ── PostFast (social scheduling) ─────────────────────────────
# Sign up at postfa.st, connect your social accounts, copy the API key
# from Dashboard → API Key. Platform-to-account mapping is resolved automatically.
POSTFAST_API_KEY=

# ── Kurelo Vercel deployment URL ──────────────────────────────
# Used by agents to call back to /api/posthog and /api/stripe
KURELO_URL=https://kurelo.vercel.app

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Existing Kurelo env vars (Vercel) ─────────────────────────
# These are set in Vercel and are NOT needed on Railway.
# Listed here for reference only.
# DASHBOARD_PASSWORD=
# DASHBOARD_SESSION_TOKEN=
# STRIPE_SECRET_KEY=
# POSTHOG_API_KEY=
# POSTHOG_CREVAXO_PROJECT_ID=
# POSTHOG_ROSTURA_PROJECT_ID=
# CREVAXO_SUPABASE_FUNCTION_URL=
# ROSTURA_SUPABASE_FUNCTION_URL=
# KURELO_DASHBOARD_SECRET=
# RESEND_API_KEY=
